{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/chat/sessions/[id]/messages",
      "regex": "^/api/chat/sessions/([^/]+?)/messages(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/chat/sessions/(?<nxtPid>[^/]+?)/messages(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/api/chat/sessions",
      "regex": "^/api/chat/sessions(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/chat/sessions(?:/)?$"
    },
    {
      "page": "/api/papers",
      "regex": "^/api/papers(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/papers(?:/)?$"
    },
    {
      "page": "/api/query",
      "regex": "^/api/query(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/query(?:/)?$"
    },
    {
      "page": "/api/upload",
      "regex": "^/api/upload(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/upload(?:/)?$"
    },
    {
      "page": "/api/workspaces",
      "regex": "^/api/workspaces(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/workspaces(?:/)?$"
    },
    {
      "page": "/workspace",
      "regex": "^/workspace(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/workspace(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}